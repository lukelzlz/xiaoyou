# 应用配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TIMEZONE=Asia/Shanghai

# Discord 配置
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# Telegram 配置
TELEGRAM_TOKEN=your_telegram_bot_token

# 自定义 API 代理配置（可选）
# DISCORD_API_URL=https://dcapi.qwqc.cc/api
# TELEGRAM_API_URL=https://tgapi.qwqc.cc/bot

# Quick 服务配置（快速响应模型）
QUICK_API_KEY=your_api_key
QUICK_API_URL=https://api.glm.ai/v1
QUICK_MODEL=quick
EMBEDDING_MODEL=embedding
VISION_MODEL=vision
QUICK_MAX_TOKENS=4096
QUICK_TEMPERATURE=0.7
QUICK_TIMEOUT=30000

# Plan 服务配置（任务规划模型）
PLAN_API_KEY=your_plan_api_key
PLAN_API_URL=https://api.nvidia.com/v1
PLAN_MODEL=plan
PLAN_MAX_TOKENS=8192
PLAN_TIMEOUT=60000

# OpenClaw 配置
OPENCLAW_API_URL=http://localhost:8080
OPENCLAW_API_KEY=your_openclaw_key
OPENCLAW_MAX_CONCURRENT=10
OPENCLAW_TASK_TIMEOUT=300000

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=xiaoyou:

# Qdrant 配置
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=xiaoyou_memories

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/xiaoyou
