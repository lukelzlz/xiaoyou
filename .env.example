# 应用配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TIMEZONE=Asia/Shanghai

# Discord 配置
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# Telegram 配置
TELEGRAM_TOKEN=your_telegram_bot_token

# 自定义 API 代理配置（可选）
# DISCORD_API_URL=https://dcapi.qwqc.cc/api
# TELEGRAM_API_URL=https://tgapi.qwqc.cc/bot

# GLM 配置
GLM_API_KEY=your_glm_api_key
GLM_API_URL=https://api.glm.ai/v1

# 模型 ID 配置（推荐使用通用前缀）
MODEL_ID=glm-4.5-air
EMBEDDING_MODEL_ID=text-embedding-3-small
VISION_MODEL_ID=glm-4.5-vision

# 兼容旧配置（优先级低于上述通用前缀）
# GLM_MODEL=glm-4.5-air
# GLM_EMBEDDING_MODEL=text-embedding-3-small
# GLM_VISION_MODEL=glm-4.5-vision

GLM_MAX_TOKENS=4096
GLM_TEMPERATURE=0.7
GLM_TIMEOUT=30000

# Nemotron 配置
NEMOTRON_API_KEY=your_nemotron_api_key
NEMOTRON_API_URL=https://api.nvidia.com/v1
NEMOTRON_MODEL=nemotron-3-super
NEMOTRON_MAX_TOKENS=8192
NEMOTRON_TIMEOUT=60000

# OpenClaw 配置
OPENCLAW_API_URL=http://localhost:8080
OPENCLAW_API_KEY=your_openclaw_key
OPENCLAW_MAX_CONCURRENT=10
OPENCLAW_TASK_TIMEOUT=300000

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=xiaoyou:

# Qdrant 配置
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=xiaoyou_memories

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/xiaoyou
