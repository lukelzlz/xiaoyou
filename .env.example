# 应用配置
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TIMEZONE=Asia/Shanghai

# Discord 配置
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id

# Telegram 配置
TELEGRAM_TOKEN=your_telegram_bot_token

# ============ LLM 服务配置 ============

# 聊天服务（快速响应、意图识别、嵌入向量）
CHAT_API_KEY=your_api_key
CHAT_API_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MAX_TOKENS=4096
CHAT_TEMPERATURE=0.7
CHAT_TIMEOUT=30000

# 多模态服务（视觉+音频识别）
OMNI_API_KEY=your_omni_api_key
OMNI_API_URL=https://api.openai.com/v1
OMNI_MODEL=gpt-4o
OMNI_MAX_TOKENS=4096
OMNI_TIMEOUT=60000

# 规划服务（复杂任务规划）
PLAN_API_KEY=your_plan_api_key
PLAN_API_URL=https://api.openai.com/v1
PLAN_MODEL=gpt-4o
PLAN_MAX_TOKENS=8192
PLAN_TIMEOUT=60000

# ============ 存储配置 ============

# Redis（热记忆存储）
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=xiaoyou:

# Qdrant（向量数据库）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=xiaoyou_memories

# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/xiaoyou

# ============ 搜索配置 ============

# Brave Search API（可选，用于网络搜索）
BRAVE_API_KEY=your_brave_api_key
# BRAVE_API_URL=https://api.search.brave.com/res/v1

# ============ 执行器配置 ============

# OpenClaw RPC（任务执行）
OPENCLAW_API_URL=http://localhost:8080
OPENCLAW_API_KEY=your_openclaw_api_key
OPENCLAW_MAX_CONCURRENT=10
OPENCLAW_TASK_TIMEOUT=300000
